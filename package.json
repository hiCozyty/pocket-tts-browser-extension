{
  "name": "pocket-tts-browser-extension",
  "version": "0.1.0",
  "description": "Browser extension that transcribes highlighted text to speech using Pocket TTS (WASM, in-browser).",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "npm run icons && vite build && node scripts/cleanup-dist.mjs",
    "icons": "node scripts/generate-icons.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.25",
    "@types/chrome": "^0.0.268",
    "@types/firefox-webext-browser": "^120.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/ui": "^4.1.9",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "pngjs": "^7.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
